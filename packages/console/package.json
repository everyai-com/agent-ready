{
  "name": "@agent-ready/console",
  "version": "0.1.0",
  "description": "Gateway Console: a self-contained owner UI + API, served from the same Worker/handler as the MCP gateway. See the capability sheet, try tools in a playground, and get connect snippets.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
