{
  "name": "@agent-ready/surface-ui",
  "version": "0.1.0",
  "description": "Turns a capability manifest tool result into per-host renderings: markdown, structured content, and self-contained HTML components.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
