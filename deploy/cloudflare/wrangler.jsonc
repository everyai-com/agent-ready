{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "agent-ready-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    // Non-secret defaults. Override secrets with `wrangler secret put`.
  }
}
