{
  "version": "v0",
  "app": {
    "name": "sample-app",
    "title": "Sample App",
    "description": "Replace this manifest.json with the one generated by the agent-ready wizard for your own Supabase project.",
    "backend": "supabase"
  },
  "resources": [
    {
      "name": "plants",
      "label": "Plants",
      "description": "Plants listed for sale",
      "fields": [
        { "name": "id", "type": "string" },
        { "name": "name", "type": "string" },
        { "name": "species", "type": "string" },
        { "name": "price_cents", "type": "number" },
        { "name": "in_stock", "type": "boolean" }
      ]
    },
    {
      "name": "orders",
      "label": "Orders",
      "description": "Customer orders",
      "fields": [
        { "name": "id", "type": "string" },
        { "name": "plant_id", "type": "string" },
        { "name": "status", "type": "string" },
        { "name": "created_at", "type": "datetime" }
      ]
    }
  ],
  "capabilities": {
    "plants": [
      {
        "verb": "read",
        "enabled": true,
        "exposedFields": ["id", "name", "species", "price_cents", "in_stock"]
      },
      {
        "verb": "list",
        "enabled": true,
        "exposedFields": ["id", "name", "species", "price_cents", "in_stock"],
        "guardrails": { "maxRowsPerCall": 100 }
      },
      { "verb": "create", "enabled": false, "exposedFields": [] },
      { "verb": "update", "enabled": false, "exposedFields": [] }
    ],
    "orders": [
      {
        "verb": "read",
        "enabled": true,
        "exposedFields": ["id", "plant_id", "status", "created_at"]
      },
      {
        "verb": "list",
        "enabled": true,
        "exposedFields": ["id", "plant_id", "status", "created_at"],
        "guardrails": { "maxRowsPerCall": 100 }
      },
      { "verb": "create", "enabled": false, "exposedFields": [] },
      { "verb": "update", "enabled": false, "exposedFields": [] }
    ]
  }
}
